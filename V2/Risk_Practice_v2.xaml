<Canvas
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800" d:DesignWidth="1200" Height="auto" Width="auto"  
    Background="#FFEFF1F1" Name="RiskPractice_v2">
  <Label x:Name="lbl_FormHeader" Content="Practice-Level Matter Risk Assessment and File Reviews - Management Area" 
         Height="32" Canvas.Left="10" Canvas.Top="10" Width="590" FontWeight="Bold" Foreground="#FF6150BE" FontSize="16"/>

  <TabControl x:Name="TC_Main" Canvas.Left="10" Canvas.Top="47" Height="743" Width="1180" Background="#FFEFF1F1" BorderBrush="Gray">
    <TabControl.Resources>
      <Style TargetType="{x:Type TabItem}">
        <!-- set default colours for not selected -->
        <Setter Property="Background" Value="#8B82B6" />
        <Setter Property="BorderBrush" Value="#FF5E577C" />
        <Setter Property="Foreground" Value="White" />

        <Style.Triggers>
          <!-- Triggers when tab is selected - set font colour to black -->
          <Trigger Property="IsSelected" Value="True" >
            <Setter Property="Foreground" Value="Black" />

          </Trigger>
          <!-- Trigger to set header text to Black on MouseOver -->
          <Trigger Property="IsMouseOver" Value="True">
            <Setter Property="Foreground" Value="Black"/>
          </Trigger>
        </Style.Triggers>
      </Style>

    </TabControl.Resources>

    <TabItem Header="Unlock Matters" x:Name="ti_ManageLocks" Height="26" Width="200" >
      <Canvas>
        <TextBlock Text="Use this page to unlock matters which were automatically locked, to allow the Fee Earner to complete one now (this resets the timer to allow another 2 weeks)." Foreground="Gray" TextWrapping="Wrap" Height="18" Width="909" Canvas.Left="10" Canvas.Top="10" />
        <TextBlock Text="NB: Matters are automatically locked after 14 days if there isn't a completed 'Matter Risk Assessment' on file. This prevents any activity on the matter from taking place (eg: Fee Earner cannot Time Record to the matter; secretaries unable to create documents etc)." Foreground="Gray" TextWrapping="Wrap" Height="38" Width="856" Canvas.Left="10" Canvas.Top="28" HorizontalAlignment="Left" VerticalAlignment="Center" />
        <TextBlock x:Name="tb_NoLockedMatters" Text="There are no Locked matters matching the 'Filter Criteria'" Foreground="Red" TextWrapping="Wrap" Canvas.Left="285" Canvas.Top="157" FontSize="22" FontWeight="Bold" />

        <ToggleButton x:Name="btn_UnlockMatters2" Canvas.Top="73" Height="79" Width="100" Canvas.Left="1012" HorizontalAlignment="Center" VerticalAlignment="Top">
          <StackPanel Orientation="Vertical">
            <Image MaxHeight="30" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\Unlock.png"/>
            <TextBlock Text="Unlock selected matter(s) ⇩" TextWrapping="Wrap" TextAlignment="Center" Width="90"/>
          </StackPanel>
        </ToggleButton>

        <!-- Popup anchored to the New button -->
        <Popup x:Name="popTemplates"
               PlacementTarget="{Binding ElementName=btn_UnlockMatters2}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">

          <Border BorderBrush="#FF616110" BorderThickness="1" CornerRadius="6"
                  Background="#FFF4F4BF" Padding="10">
            <StackPanel MinWidth="260">

              <TextBlock Text="Please select reason for unlocking:"
                         FontWeight="SemiBold"
                         Margin="0,0,0,8"/>

              <!-- Scroll if lots of templates -->
              <ScrollViewer MaxHeight="290" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="icTemplates">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <!-- Show Name, keep TemplateID in Tag -->
                      <Button Tag="{Binding}"
                              Margin="0,0,0,6"
                              HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Vertical">
                          <TextBlock Text="{Binding Reason}" 
                                     FontWeight="SemiBold" TextAlignment="Center"
                                     TextWrapping="Wrap" MaxWidth="320"/>
                        </StackPanel>

                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>

              <Separator Margin="0,8,0,8"/>

              <Button x:Name="btnCancel"
                      Content="Cancel"
                      HorizontalAlignment="Right"
                      Width="80"/>
            </StackPanel>
          </Border>
        </Popup>



        <GroupBox Header="Filter Criteria..." Foreground="#FF6150BE" BorderBrush="Gray" Height="86" Width="990" Canvas.Left="10" Canvas.Top="66">
          <Canvas>
            <Label Content="Fee Earner" Foreground="#FF6150BE" Canvas.Left="10" HorizontalContentAlignment="Right" Canvas.Top="34" />
            <ComboBox x:Name="cboFeeEarner" Canvas.Left="80" Width="195" Height="26" Canvas.Top="34" >
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Code, Mode=TwoWay}" Width="38" />
                    <TextBlock Text="{Binding Name, Mode=TwoWay}" Width="180" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Label Content="Department" Foreground="#FF6150BE" Canvas.Left="2" HorizontalContentAlignment="Right" Canvas.Top="3" />
            <ComboBox x:Name="cboDept" Canvas.Left="80" Width="195" Height="26" Canvas.Top="3">
              <!--<ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Code, Mode=TwoWay}" Width="180" />
                                        <TextBlock Text="{Binding Name, Mode=TwoWay}" Width="0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>-->

            </ComboBox>
            <Label Content="Text Search" Foreground="#FF6150BE" Canvas.Left="280" Width="75" HorizontalContentAlignment="Right"  />
            <Label Foreground="Gray" Content="(searches: Client Name, Matter Description)" Canvas.Left="563" Width="235" HorizontalContentAlignment="Left" FontStyle="Italic"  />
            <TextBox x:Name="txtSearch" Width="199" Canvas.Left="360" Height="26" VerticalContentAlignment="Center" />

            <Label Content="Entity Ref / Matter No" Foreground="#FF6150BE" Canvas.Top="31" Width="134" HorizontalContentAlignment="Right"  Canvas.Left="299"  />
            <TextBox x:Name="txtEntityRef" Width="65" Canvas.Left="438" Canvas.Top="31" Height="26" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" />
            <Label Content="/" Foreground="#FF6150BE" Canvas.Top="31" Width="15" HorizontalContentAlignment="Left"  Canvas.Left="504"  />
            <TextBox x:Name="txtMatterNo" Width="40" Canvas.Left="519" Canvas.Top="31" Height="26" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />

            <Button x:Name="btn_RefreshLockedMatters" Content="Search" Background="#FF91E888" BorderBrush="DarkGreen"  Canvas.Left="718" Height="26" Width="70" Canvas.Top="31" />
            <Button x:Name="btn_ClearLockedMattersFilters" Content="Clear Filters - View All" Background="#FFF0B8B8" BorderBrush="DarkRed"
                    ToolTip="Click here to clear all filter criteria and view all locked matters" Canvas.Left="572" Height="26" Width="128" Canvas.Top="31" />

            <StackPanel Orientation="Vertical" Canvas.Left="816" Canvas.Top="6" Visibility="Visible">
              <Label Content="Group By" Foreground="#FF6150BE" />
              <ComboBox x:Name="cbo_GroupBy" Width="155" >
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                      <TextBlock Text="{Binding FriendlyName, Mode=TwoWay}" Width="150" />
                      <TextBlock Text="{Binding CodeName, Mode=TwoWay}" Width="0" Visibility="Hidden"/>
                    </StackPanel>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

            </StackPanel>
          </Canvas>
        </GroupBox>


        <DataGrid x:Name="dg_LockedMatters" Height="553" Width="1174" Canvas.Top="157" AlternatingRowBackground="#FFAEDEB9" 
                  AutoGenerateColumns="False" IsTextSearchEnabled="True" SelectionMode="Single" FrozenColumnCount="1"
                  CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible"
                  BorderBrush="Gray" BorderThickness="1">
          <DataGrid.Resources>
            <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}" >
              <Setter Property="Margin" Value="0,2,0,4"/>
              <!--<Setter Property="Padding" Value="0,2,0,0" />-->
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="{x:Type GroupItem}" >
                    <Expander x:Name="exp" IsExpanded="True"
                              Background="LightGray" BorderBrush="LightGray" BorderThickness="1,1,1,4"
                              Foreground="Black" Padding="0,2,0,0">
                      <Expander.Header>
                        <DockPanel>
                          <TextBlock FontWeight="Bold" Text="{Binding Path=Name}" Margin="5,0,0,0" />
                          <TextBlock Text=" (" FontWeight="Bold" />
                          <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}"/>
                          <TextBlock Text=")" FontWeight="Bold" />
                        </DockPanel>
                      </Expander.Header>
                      <ItemsPresenter />
                    </Expander>

                  </ControlTemplate>
                </Setter.Value>
              </Setter>

            </Style>
            <Style x:Key="RightAligned" TargetType="DataGridCell">
              <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>
            <Style x:Key="Center" TargetType="DataGridCell">
              <Setter Property="TextBlock.TextAlignment" Value="Center" />
            </Style>
            <Style x:Key="DubHeightColumn" TargetType="DataGridColumnHeader">
              <Setter Property="ContentTemplate">
                <Setter.Value>
                  <DataTemplate>
                    <TextBlock TextWrapping="Wrap" Text="{Binding}" TextAlignment="Center" Width="{Binding}"/>
                  </DataTemplate>
                </Setter.Value>
              </Setter>
              <Setter Property="HorizontalContentAlignment" Value="Center" />
              <Setter Property="VerticalContentAlignment" Value="Center" />
              <Setter Property="BorderThickness" Value="1" />
              <Setter Property="Width" Value="Auto" />
              <Setter Property="Height" Value="42"/>
            </Style>
          </DataGrid.Resources>

          <DataGrid.GroupStyle>
            <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}" >
              <GroupStyle.Panel>
                <ItemsPanelTemplate >
                  <DataGridRowsPresenter />
                </ItemsPanelTemplate>
              </GroupStyle.Panel>
            </GroupStyle>
          </DataGrid.GroupStyle>

          <DataGrid.Columns>
            <DataGridTextColumn Header="Our Ref" Binding="{Binding EntityRefMN}" IsReadOnly="True" />
            <DataGridTextColumn Header="Client Name" Binding="{Binding ClName}" IsReadOnly="True" Width="150"/>
            <DataGridTextColumn Header="Matter Description" Binding="{Binding MatDesc}" IsReadOnly="True" Width="150"/>
            <DataGridTextColumn Header="Fee Earner" Binding="{Binding FeeEarner}" IsReadOnly="True" />
            <DataGridTextColumn Header="Department" Binding="{Binding Department}" IsReadOnly="True" />
            <DataGridTextColumn Header="Matter Opened" Binding="{Binding MatterOpened, StringFormat='dd/MM/yyyy'}" CellStyle="{StaticResource RightAligned}" IsReadOnly="True" />
            <DataGridTextColumn Header="Days Since Matter Open" 
                                CellStyle="{StaticResource Center}"   
                                Binding="{Binding DaysSinceMatterOpen}" IsReadOnly="True" 
                                HeaderStyle="{StaticResource DubHeightColumn}" Width="80"/>
            <DataGridTextColumn Header="EntityRef" Binding="{Binding EntityRef}" IsReadOnly="True" Visibility="Hidden"/>
            <DataGridTextColumn Header="MatterNo" Binding="{Binding MatterNo}" IsReadOnly="True" Visibility="Hidden"/>

            <!--<DataGridTextColumn Header="Expiry Date" Binding="{Binding MRA_ExpiryDate}" IsReadOnly="True" />-->
            <DataGridTextColumn Header="MRA ID" Binding="{Binding MRA_ID}" 
                                CellStyle="{StaticResource Center}" IsReadOnly="True" />
            <DataGridTextColumn Header="MRA Name" Binding="{Binding MRA_Name}" IsReadOnly="True" />
            <DataGridTextColumn Header="MRA Current Expiry Date" 
                                Binding="{Binding MRA_ExpiryCurrent, StringFormat='dd/MM/yyyy'}" 
                                HeaderStyle="{StaticResource DubHeightColumn}" Width="90" IsReadOnly="True" />
            <DataGridTextColumn Header="Default Expiry Days" 
                                Binding="{Binding MRA_TTExpiryDays}" IsReadOnly="True" 
                                HeaderStyle="{StaticResource DubHeightColumn}" Width="70"/>
          </DataGrid.Columns>
        </DataGrid>


      </Canvas>
    </TabItem>

    <TabItem Header="Configure Matter Risk Assessments" x:Name="ti_Defaults" Width="200">
      <ScrollViewer Tag="VIEW:'00) MRAv2 Setup' UPDATE=YES" VerticalScrollBarVisibility="Disabled" HorizontalAlignment="Left" VerticalAlignment="Top"/>
    </TabItem>


    <TabItem Header="Configure File Reviews" x:Name="ti_Setup_FileReview" Width="200">
      <Canvas>
        <Label Content="Use this page to configure a File Review template and set which Case Types (or Departments) should use which" Foreground="Gray" Canvas.Left="10" Canvas.Top="10" Width="812" />

        <TabControl x:Name="tc_FR" Canvas.Left="10" Canvas.Top="40" Height="660" Width="1154" Background="#FFEFF1F1" BorderBrush="Gray" TabStripPlacement="Top" >
          <TabItem Header="File Review Overview" x:Name="ti_FR_Overview" >
            <Canvas>
              <GroupBox Header="List of 'File Review' templates" BorderBrush="Gray" Foreground="Gray" Height="611" Width="443" Canvas.Left="10" Canvas.Top="10">
                <StackPanel Orientation="Vertical">

                  <StackPanel Orientation="Horizontal" Margin="4" HorizontalAlignment="Center">
                    <Button x:Name="btn_AddNew_FRTemplate">
                      <StackPanel Orientation="Horizontal">
                        <Image MaxHeight="20" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\plus.png"/>
                        <TextBlock Margin="3,4,0,4" Text="Add New..."  TextWrapping="Wrap" Width="50" TextAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Button x:Name="btn_CopySelected_FRTemplate" Margin="8,0,0,0">
                      <StackPanel Orientation="Horizontal">
                        <Image MaxHeight="20" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\Copy(small).png"/>
                        <TextBlock Margin="3,4,0,4" Text="Duplicate Selected" TextWrapping="Wrap" Width="60" TextAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Button x:Name="btn_Preview_FRTemplate" Margin="8,0,0,0" Visibility="Collapsed">
                      <StackPanel Orientation="Horizontal">
                        <Image MaxHeight="20" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\Test2.png"/>
                        <TextBlock Margin="3,4,0,4" Text="Preview Selected"  TextWrapping="Wrap" Width="50" TextAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Button x:Name="btn_Edit_FRTemplate"  Margin="8,0,0,0">
                      <StackPanel Orientation="Horizontal">
                        <Image MaxHeight="20" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\Edit1.png"/>
                        <TextBlock Margin="3,4,0,4" Text="Edit Selected"  TextWrapping="Wrap" Width="50" TextAlignment="Center"/>
                      </StackPanel>
                    </Button>

                    <Button x:Name="btn_DeleteSelected_FRTemplate" Background="#FFFFA7A7" BorderBrush="DarkRed" Margin="8,0,0,0">
                      <StackPanel Orientation="Horizontal">
                        <Image MaxHeight="20" Source="\\tw-p4wapp01\Partner\Managing Partner\Other Resources\trash.png"/>
                        <TextBlock Margin="3,4,0,4" Text="Delete Selected" TextWrapping="Wrap" Width="50" TextAlignment="Center"/>
                      </StackPanel>
                    </Button>

                  </StackPanel>

                  <StackPanel Orientation="Vertical" Canvas.Left="359" Canvas.Top="10" Width="69"  Visibility="Collapsed">
                    <Label x:Name="lbl_FR_Template_ID" Content="-ID-" Foreground="Gray" HorizontalContentAlignment="Right"/>
                    <Label x:Name="lbl_FR_Template_Name" Content="-Name-" Foreground="Gray" HorizontalContentAlignment="Right"/>
                  </StackPanel>

                  <DataGrid x:Name="dg_FR_Templates" Height="528" Margin="4" BorderBrush="Gray" BorderThickness="1"
                            AlternatingRowBackground="#FFAEDEB9" SelectionMode="Single" AutoGenerateColumns="False" IsTextSearchEnabled="True" 
                            CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible">
                    <DataGrid.Resources>
                      <Style x:Key="RightAligned" TargetType="DataGridCell">
                        <Setter Property="HorizontalAlignment" Value="Right"/>
                      </Style>
                      <Style x:Key="Center" TargetType="DataGridCell">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                      </Style>
                      <Style x:Key="EditableColumn" TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="Green"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="Wheat"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Width" Value="Auto"/>
                      </Style>
                      <Style x:Key="TotalColumn" TargetType="DataGridColumnHeader">
                        <Setter Property="HorizontalContentAlignment" Value="Right"/>
                        <Setter Property="BorderBrush" Value="Black"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                      </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Code" IsReadOnly="True" Width="40" Binding="{Binding mraT_Code}"/>
                      <DataGridTextColumn Header="Friendly Name" IsReadOnly="False" Width="220" Binding="{Binding mraT_Desc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                HeaderStyle="{StaticResource EditableColumn}"/>
                      <DataGridTextColumn Header="Num times used" IsReadOnly="True" Width="100" Binding="{Binding CountUsed}"/>
                      <DataGridTextColumn Header="Q Count" IsReadOnly="True" Width="100" 
                                                                Binding="{Binding QCount}"/>
                      <!--<DataGridTextColumn Header="ID" IsReadOnly="True" Width="100" Binding="{Binding ID}"/>-->

                    </DataGrid.Columns>
                  </DataGrid>

                </StackPanel>
              </GroupBox>

              <GroupBox Header="List of 'Case Types' or 'Departments' and 'File Review' Template to use" Foreground="Gray" BorderBrush="Gray" Height="611" Width="680" Canvas.Left="458" Canvas.Top="10">
                <Grid x:Name="grd_MainFR"  >
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" MinWidth="90" MaxWidth="660" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                  </Grid.ColumnDefinitions>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="26" />
                    <RowDefinition Height="410" />
                    <RowDefinition Height="35" />
                    <RowDefinition  />
                  </Grid.RowDefinitions>

                  <Label Content="DEPARTMENTS" HorizontalContentAlignment="Center" Foreground="Gray" Grid.Row="0" Grid.Column="0" Margin="0,0,6,0" />
                  <Label Content="CASE TYPES in selected Department" HorizontalContentAlignment="Center" Foreground="Gray" Grid.Row="0" Grid.Column="2" Margin="6,0,0,0" />

                  <GridSplitter HorizontalAlignment="Center"   
                                                  VerticalAlignment="Stretch"   
                                                  Grid.Column="1"   
                                                  Grid.RowSpan="4"
                                                  Width="6" Background="Silver">
                    <GridSplitter.Template>
                      <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Grid>
                          <Button Content="⁞" FontWeight="Bold"/>
                          <!-- Use vertical ellipsis character as the arrow -->
                          <Rectangle Fill="#00FFFFFF" />
                          <!-- Transparent background to allow resizing -->
                        </Grid>
                      </ControlTemplate>
                    </GridSplitter.Template>
                  </GridSplitter>

                  <DataGrid x:Name="dg_DepartmentsFR" Grid.Row="1" Grid.Column="0" BorderBrush="Gray" BorderThickness="1"
                            AlternatingRowBackground="#FFAEDEB9" SelectionMode="Single" AutoGenerateColumns="False" IsTextSearchEnabled="True" Margin="0,0,6,0"
                            CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible">

                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Department Name" IsReadOnly="True" Width="Auto" Binding="{Binding mraTD_DeptN}"/>
                      <DataGridTextColumn Header="Default Template" IsReadOnly="False" Width="Auto" Binding="{Binding mraTD_DeptDefaultN}"/>
                      <DataGridTextColumn Header="TemplateID" IsReadOnly="False" Width="220" Binding="{Binding mraTD_DeptDefaultID}" Visibility="Hidden"/>
                      <DataGridTextColumn Header="Department ID" IsReadOnly="True" Width="Auto" Binding="{Binding mraTD_DeptID}" Visibility="Hidden"/>
                      <DataGridTextColumn Header="CTG ID" IsReadOnly="True" Width="Auto" Binding="{Binding mraTD_CTGID}" Visibility="Hidden"/>
                    </DataGrid.Columns>

                  </DataGrid>

                  <DataGrid x:Name="dg_FR_CaseTypes_FRTemplate" Grid.Row="1" Grid.Column="2" BorderBrush="Gray" BorderThickness="1"
                            AlternatingRowBackground="#FFAEDEB9" SelectionMode="Single" AutoGenerateColumns="False" IsTextSearchEnabled="True" Margin="6,0,0,0" Grid.RowSpan="2" 
                            CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible">

                    <DataGrid.Columns>
                      <DataGridTextColumn Header="Case Type Name" IsReadOnly="True" Width="120" Binding="{Binding mraT_CTName}"/>
                      <DataGridTextColumn Header="Template to use..." IsReadOnly="False" Width="220" Binding="{Binding mraT_CTTemplateToUse}"/>

                      <DataGridTextColumn Header="RowID" IsReadOnly="False" Width="220" Binding="{Binding mraT_RowID}" Visibility="Hidden"/>
                      <DataGridTextColumn Header="TemplateID" IsReadOnly="False" Width="220" Binding="{Binding mraT_TemplateID}" Visibility="Hidden"/>
                      <DataGridTextColumn Header="CT ID" IsReadOnly="False" Width="220" Binding="{Binding mraT_CTid}" Visibility="Hidden"/>
                      <DataGridTextColumn Header="CTG Name" IsReadOnly="False" Width="220" Binding="{Binding mraT_CTGName}" Visibility="Hidden"/>
                    </DataGrid.Columns>
                  </DataGrid>

                  <GroupBox Header="Edit Default for Department..." Foreground="Gray" BorderBrush="Gray" Grid.Row="2" Grid.Column="0" Margin="0,0,6,0" Grid.RowSpan="2" >
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                      </Grid.RowDefinitions>

                      <Label Content="Selected Dept:" Foreground="#FF6150BE" HorizontalContentAlignment="Right" Grid.Row="1" Grid.Column="0"/>
                      <Label x:Name="lbl_SelectedDeptNameFR" Content="-Dept-" Foreground="#FF6150BE" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                      <Label x:Name="lbl_SelectedDeptIDFR" Content="-ID-" Foreground="#FF6150BE" Grid.Row="5" Grid.Column="2" HorizontalContentAlignment="Right" Visibility="Hidden"/>

                      <Label Content="Template to use:" Foreground="#FF6150BE" Grid.Row="3" HorizontalContentAlignment="Right" />
                      <ComboBox x:Name="cbo_FR_Department_TemplateToUse" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" >
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding mraT_Code, Mode=TwoWay}" Width="0"  Visibility="Hidden"/>
                              <TextBlock Text="{Binding mraT_Desc, Mode=TwoWay}" Width="Auto" />
                              <TextBlock Text="{Binding CountUsed, Mode=TwoWay}" Width="0"  Visibility="Hidden"/>
                              <TextBlock Text="{Binding QCount, Mode=TwoWay}" Width="0" Visibility="Hidden"/>
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
                      <CheckBox x:Name="chk_FR_ApplyToAllCaseTypes" IsChecked="True" Content="?Apply to all Case Types" Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" VerticalAlignment="Center" FlowDirection="RightToLeft" Foreground="#FF6150BE" HorizontalAlignment="Center">
                        <CheckBox.Resources>
                          <Style TargetType="{x:Type Path}">
                            <Setter Property="FlowDirection" Value="LeftToRight" />
                          </Style>
                        </CheckBox.Resources>
                      </CheckBox>
                      <Button x:Name="btn_Save_FR_TemplateToUseForDept" IsEnabled="False" MaxWidth="70" Content="Save" Grid.Row="7" Grid.Column="1"/>
                    </Grid>
                  </GroupBox>

                  <GroupBox Header="Edit selected CaseType..." Foreground="Gray" BorderBrush="Gray" Grid.Row="3" Grid.Column="2" Margin="6,0,0,0" >
                    <Grid>
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                        <RowDefinition Height="26" />
                        <RowDefinition Height="2" />
                      </Grid.RowDefinitions>

                      <Label Content="Selected CaseType:" Foreground="#FF6150BE" HorizontalContentAlignment="Right" Grid.Row="1" Grid.Column="0"/>
                      <Label x:Name="lbl_SelectedCaseTypeFR" Content="-CaseType-" Foreground="#FF6150BE" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"/>
                      <Label x:Name="lbl_SelectedCaseTypeIDFR" Content="-ID-" Foreground="#FF6150BE" Grid.Row="5" Grid.Column="2" HorizontalContentAlignment="Right" Visibility="Hidden"/>

                      <Label Content="Template to use:" Foreground="#FF6150BE" Grid.Row="3" HorizontalContentAlignment="Right" />
                      <ComboBox x:Name="cbo_FR_CaseType_TemplateToUse" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" >
                        <ComboBox.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Text="{Binding mraT_Code, Mode=TwoWay}" Width="0" Visibility="Hidden" />
                              <TextBlock Text="{Binding mraT_Desc, Mode=TwoWay}" Width="Auto" />
                              <TextBlock Text="{Binding CountUsed, Mode=TwoWay}" Width="0" Visibility="Hidden" />
                              <TextBlock Text="{Binding QCount, Mode=TwoWay}" Width="0" Visibility="Hidden"/>
                            </StackPanel>
                          </DataTemplate>
                        </ComboBox.ItemTemplate>
                      </ComboBox>
