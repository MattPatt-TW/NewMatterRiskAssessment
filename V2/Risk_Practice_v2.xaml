                <DataGridTextColumn Header="TemplateNames" IsReadOnly="True" Visibility="Collapsed"
                                    Binding="{Binding TemplateNames}"/>
              </DataGrid.Columns>
            </DataGrid>


          </StackPanel>

        </Border>


      </StackPanel>
    </TabItem>

  </TabControl>
</Canvas>
