          <StackPanel Orientation="Vertical" >
            <StackPanel Orientation="Horizontal" >
              <TextBlock Text="Lock Code:" Foreground="Gray" Width="90" TextAlignment="Right"/>
              <TextBlock x:Name="tb_LockCode" Foreground="Gray" Margin="4,0,0,0" Text="57 (Dev) | 146 (Live)"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" >
              <TextBlock Text="Lock Description:" Foreground="Gray" Width="90" TextAlignment="Right"/>
              <TextBlock x:Name="tb_LockDesc" Foreground="Gray" Margin="4,0,0,0" Text="XAML_Screen_HOD_AccessOnly"/>
            </StackPanel>

          </StackPanel>
        </GroupBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">

          <Border CornerRadius="16" Padding="8" BorderBrush="DarkRed" Background="#FFCE3F3F" BorderThickness="1">
            <StackPanel Orientation="Vertical">
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="Users who cannot access HOD screens" FontSize="14" VerticalAlignment="Center" Foreground="White"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="50,0,0,0">
                  <TextBox x:Name="txt_Search" Width="151" Height="23" VerticalContentAlignment="Center"  Text="" Padding="2,0,0,0"/>
                  <TextBlock IsHitTestVisible="False" Text="Search here..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="DarkGray" Margin="-222,0,0,0">
                    <TextBlock.Style>
                      <Style TargetType="{x:Type TextBlock}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Text, ElementName=txt_Search}" Value="">
                            <Setter Property="Visibility" Value="Visible"/>
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </TextBlock.Style>
                  </TextBlock>
                </StackPanel>

              </StackPanel>

              <DataGrid x:Name="dg_UsersWithoutKey"  AllowDrop="True"
                        AlternatingRowBackground="#FFAEDEB9" BorderBrush="Gray"
                        AutoGenerateColumns="False" 
                        IsTextSearchEnabled="True" 
                        SelectionMode="Extended" 
                        CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible" 
                        Margin="0,4,0,0" Height="544" Width="440">

                <!-- Keep selected row highlighted -->
                <DataGrid.Resources>
                  <Style TargetType="{x:Type DataGridRow}">
                    <Style.Resources>
                      <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF0078D7" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF0078D7" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White" />
                    </Style.Resources>
                  </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                  <DataGridTextColumn Header="Code" Binding="{Binding iCode}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Name" Binding="{Binding iName}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Job Title" Binding="{Binding iJobTitle}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Department" Binding="{Binding iDept}" Width="auto" IsReadOnly="True" />

                </DataGrid.Columns>
              </DataGrid>

            </StackPanel>
            
          </Border>
          

          <StackPanel Orientation="Vertical" Margin="8" VerticalAlignment="Center">
            <Button x:Name="btn_AddUserKey" Content="Add &gt;&gt;"  Height="38"  Background="#FF409040" BorderBrush="DarkGreen" Foreground="White" Padding="4"/>
            <Button x:Name="btn_RemoveUserKey" Content="&lt;&lt; Remove"  Height="38" Background="#FFCE3F3F" BorderBrush="DarkRed" Foreground="White" Margin="0,24,0,0" Padding="4"/>
          </StackPanel>


          <Border CornerRadius="16" Padding="8" BorderBrush="DarkGreen" Background="#FF409040" BorderThickness="1">
            <StackPanel Orientation="Vertical">
              <TextBlock Text="Users who CAN access HOD screens" FontSize="14" Foreground="White"/>

              <DataGrid x:Name="dg_UsersWithKey"  AllowDrop="True"
                        AlternatingRowBackground="#FFAEDEB9" BorderBrush="Gray"
                        AutoGenerateColumns="False" 
                        IsTextSearchEnabled="True" 
                        SelectionMode="Extended" 
                        CanUserResizeRows="False" HeadersVisibility="Column" RowDetailsVisibilityMode="Visible"  
                        Margin="0,4,0,0" Height="548" Width="458">

                <!--Need to add DataGrid Grouping here to go off our 'IT, Risk, Accounts...' group vs individually added users-->
                <DataGrid.Resources>
                  <!-- Keep selected row highlighted -->
                  <Style TargetType="{x:Type DataGridRow}">
                    <Style.Resources>
                      <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FF0078D7" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#FF0078D7" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                      <SolidColorBrush x:Key="{x:Static SystemColors.ControlTextBrushKey}" Color="White" />
                    </Style.Resources>
                  </Style>

                  <Style x:Key="GroupHeaderStyle" TargetType="{x:Type GroupItem}" >
                    <Setter Property="Margin" Value="0,2,0,4"/>
                    <!--<Setter Property="Padding" Value="4,0,0,0" />-->
                    <Setter Property="Template">
                      <Setter.Value>
                        <ControlTemplate TargetType="{x:Type GroupItem}" >
                          <Expander x:Name="exp" IsExpanded="True"
                                    Background="LightGray" BorderBrush="#FF4E4E4E" BorderThickness="1,1,1,1"
                                    Foreground="Black" Padding="0,2,0,0" Margin="2,0">
                            <Expander.Header>
                              <DockPanel>
                                <TextBlock FontWeight="Bold" Text="{Binding Path=Name}" Margin="5,0,0,0" />
                                <TextBlock Text=" (" FontWeight="Bold" />
                                <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}"/>
                                <TextBlock Text=")" FontWeight="Bold" />
                              </DockPanel>
                            </Expander.Header>
                            <ItemsPresenter />
                          </Expander>

                        </ControlTemplate>
                      </Setter.Value>
                    </Setter>

                    <!-- Trigger to set background colour to GREEN for 'Accounts, Archiving, Risk, Management, IT' -->
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding Path=Name}" Value="Accounts, Archiving, Risk, Management, IT">
                        <Setter Property="Template">
                          <Setter.Value>
                            <ControlTemplate TargetType="{x:Type GroupItem}">
                              <Expander x:Name="expander"
                                        IsExpanded="True"
                                        Background="#FF58B940"
                                        BorderBrush="#FF306323"
                                        BorderThickness="1,1,1,1"
                                        Foreground="Black"
                                        Padding="0,2,0,0"
                                        Margin="2,0">
                                <Expander.Header>
                                  <DockPanel>
                                    <TextBlock FontWeight="Bold" Text="Accounts, Archiving, Risk, Management, IT" Margin="5,0,0,0" />
                                    <TextBlock Text=" (" FontWeight="Bold" />
                                    <TextBlock FontWeight="Bold" Text="{Binding Path=ItemCount}"/>
                                    <TextBlock Text=")" FontWeight="Bold" />
                                  </DockPanel>
                                </Expander.Header>
                                <ItemsPresenter />
                              </Expander>
                            </ControlTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                    </Style.Triggers>

                  </Style>

                </DataGrid.Resources>

                <DataGrid.GroupStyle>
                  <GroupStyle ContainerStyle="{StaticResource GroupHeaderStyle}" >
                    <GroupStyle.Panel>
                      <ItemsPanelTemplate >
                        <DataGridRowsPresenter />
                      </ItemsPanelTemplate>
                    </GroupStyle.Panel>
                  </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.Columns>
                  <DataGridTextColumn Header="Code" Binding="{Binding iCode}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Name" Binding="{Binding iName}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Job Title" Binding="{Binding iJobTitle}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Department" Binding="{Binding iDept}" Width="auto" IsReadOnly="True" />
                  <DataGridTextColumn Header="Group" Binding="{Binding iGroup}" Width="auto" IsReadOnly="True" Visibility="Collapsed"/>
                </DataGrid.Columns>
              </DataGrid>

            </StackPanel>
            
          </Border>

        </StackPanel>
      </StackPanel>

    </TabItem>

    
    <TabItem Header="Reporting - Blindspots" Width="150">
