                  </GroupStyle.Panel>
                </GroupStyle>
              </DataGrid.GroupStyle>

              <DataGrid.Columns>
                <DataGridTextColumn Header="CaseType" IsReadOnly="True" 
                                    Binding="{Binding CaseType}"
                                    CellStyle="{StaticResource HighlightMissing}"
                                    Width="180">
                  <DataGridTextColumn.ElementStyle>
                    <Style TargetType="TextBlock">
                      <Setter Property="TextWrapping" Value="Wrap"/>
                    </Style>
                  </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="MRA Template Name(s)" IsReadOnly="True" 
