                  </GroupStyle.Panel>
                </GroupStyle>
              </DataGrid.GroupStyle>
              
              <DataGrid.Columns>
                <DataGridTextColumn Header="Dept" IsReadOnly="True" Visibility="Collapsed"
                                    Binding="{Binding DeptName}"/>
