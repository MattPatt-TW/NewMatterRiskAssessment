    </TabItem>



    <TabItem Header="HODs and Access Privileges" Width="200" >
      <StackPanel>
        <TextBlock Text="Use this page to manage who can access 'Heads of Department (HOD)' Screens (WIP Review WriteOff; NMRA HOD Approvals)" 
                   TextWrapping="Wrap" Foreground="Gray" Canvas.Top="10" Height="20" Width="708" Canvas.Left="10"/>

